{
  "mcpServers": {
    "jcodemunch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "jcodemunch-mcp"
      ],
      "env": {}
    },
    "jdocmunch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "jdocmunch-mcp"
      ],
      "env": {}
    },
    "context": {
      "type": "stdio",
      "command": "context",
      "args": [
        "serve"
      ],
      "env": {}
    },
    "tessl": {
      "type": "stdio",
      "command": "tessl",
      "args": [
        "mcp",
        "start"
      ]
    }
  }
}
